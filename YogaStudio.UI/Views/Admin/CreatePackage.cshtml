@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Paket Ekle";
}

<div class="page-header">
    <h3 class="page-title">Paket Ekle</h3>
    <a href="/Admin/Packages" class="btn btn-secondary">
        <i class="mdi mdi-arrow-left"></i> Geri
    </a>
</div>

<div class="row">
    <div class="col-md-6 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <form asp-action="CreatePackage" asp-controller="Admin" method="post">
                    <div class="form-group">
                        <label>Paket Adı</label>
                        <input type="text" name="Name" class="form-control" placeholder="Paket adı" required />
                    </div>
                    <div class="form-group">
                        <label>Ders Sayısı</label>
                        <input type="number" name="LessonCount" class="form-control" placeholder="Ders sayısı" min="1" required />
                    </div>
                    <div class="form-group">
                        <label>Fiyat ($)</label>
                        <input type="number" name="Price" class="form-control" placeholder="Fiyat" min="0" step="0.01" required />
                    </div>
                    <button type="submit" class="btn btn-primary mr-2">Kaydet</button>
                    <a href="/Admin/Packages" class="btn btn-light">İptal</a>
                </form>
            </div>
        </div>
    </div>
</div>
