@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Admin Dashboard";
}

<div class="page-header">
    <h3 class="page-title">Dashboard</h3>
</div>

<div class="row">
    <div class="col-xl-3 col-sm-6 grid-margin stretch-card">
        <div class="card bg-primary">
            <div class="card-body px-3 py-4">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="color-card">
                        <p class="mb-0 color-card-head text-white">Dersler</p>
                        <h2 class="text-white">@ViewBag.LessonCount</h2>
                    </div>
                    <i class="card-icon-indicator mdi mdi-calendar bg-inverse-icon-primary"></i>
                </div>
                <a href="/Admin/Lessons" class="text-white"><small>Tümünü Gör</small></a>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6 grid-margin stretch-card">
        <div class="card bg-success">
            <div class="card-body px-3 py-4">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="color-card">
                        <p class="mb-0 color-card-head text-white">Eğitmenler</p>
                        <h2 class="text-white">@ViewBag.TrainerCount</h2>
                    </div>
                    <i class="card-icon-indicator mdi mdi-account bg-inverse-icon-success"></i>
                </div>
                <a href="/Admin/Trainers" class="text-white"><small>Tümünü Gör</small></a>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6 grid-margin stretch-card">
        <div class="card bg-warning">
            <div class="card-body px-3 py-4">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="color-card">
                        <p class="mb-0 color-card-head text-white">Rezervasyonlar</p>
                        <h2 class="text-white">@ViewBag.ReservationCount</h2>
                    </div>
                    <i class="card-icon-indicator mdi mdi-bookmark bg-inverse-icon-warning"></i>
                </div>
                <a href="/Admin/Reservations" class="text-white"><small>Tümünü Gör</small></a>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6 grid-margin stretch-card">
        <div class="card bg-danger">
            <div class="card-body px-3 py-4">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="color-card">
                        <p class="mb-0 color-card-head text-white">Kullanıcılar</p>
                        <h2 class="text-white">@ViewBag.UserCount</h2>
                    </div>
                    <i class="card-icon-indicator mdi mdi-account-multiple bg-inverse-icon-danger"></i>
                </div>
                <a href="/Admin/Users" class="text-white"><small>Tümünü Gör</small></a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Son Rezervasyonlar</h4>
                <div class="table-responsive">
                    <table class="table">
                        <thead class="bg-light">
                            <tr>
                                <th>Kullanıcı</th>
                                <th>Ders</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.RecentReservations != null)
                            {
                                @foreach (var r in ViewBag.RecentReservations)
                                {
                                    <tr>
                                        <td>@r.UserName</td>
                                        <td>@r.LessonName</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Hızlı Erişim</h4>
                <div class="row mt-3">
                    <div class="col-6 mb-3">
                        <a href="/Admin/CreateLesson" class="btn btn-primary btn-block">
                            <i class="mdi mdi-plus"></i> Ders Ekle
                        </a>
                    </div>
                    <div class="col-6 mb-3">
                        <a href="/Admin/CreateTrainer" class="btn btn-success btn-block">
                            <i class="mdi mdi-plus"></i> Eğitmen Ekle
                        </a>
                    </div>
                    <div class="col-6 mb-3">
                        <a href="/Admin/CreatePackage" class="btn btn-warning btn-block">
                            <i class="mdi mdi-plus"></i> Paket Ekle
                        </a>
                    </div>
                    <div class="col-6 mb-3">
                        <a href="/Admin/CreateBlog" class="btn btn-info btn-block">
                            <i class="mdi mdi-plus"></i> Blog Ekle
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
