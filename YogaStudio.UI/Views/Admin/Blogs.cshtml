@using YogaStudio.UI.Models
@model List<BlogViewModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Blog Yazıları";
}

<div class="page-header">
    <h3 class="page-title">Blog Yazıları</h3>
    <a href="/Admin/CreateBlog" class="btn btn-primary">
        <i class="mdi mdi-plus"></i> Yeni Blog Ekle
    </a>
</div>

<div class="row">
    <div class="col-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table">
                        <thead class="bg-light">
                            <tr>
                                <th>#</th>
                                <th>Başlık</th>
                                <th>Tarih</th>
                                <th>İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || !Model.Any())
                            {
                                <tr><td colspan="4" class="text-center">Henüz blog yazısı eklenmemiş.</td></tr>
                            }
                            else
                            {
                                @foreach (var blog in Model)
                                {
                                    <tr>
                                        <td>@blog.BlogPostId</td>
                                        <td>@blog.Title</td>
                                        <td>@blog.CreatedAt.ToString("dd.MM.yyyy")</td>
                                        <td>
                                            <form asp-action="DeleteBlog" asp-controller="Admin" method="post" style="display:inline;">
                                                <input type="hidden" name="id" value="@blog.BlogPostId" />
                                                <button type="submit" class="btn btn-sm btn-danger"
                                                        onclick="return confirm('Silmek istediğinize emin misiniz?')">
                                                    <i class="mdi mdi-delete"></i> Sil
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
