@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Yorum Ekle";
}

<div class="page-header">
    <h3 class="page-title">Yorum Ekle</h3>
    <a href="/Admin/Testimonies" class="btn btn-secondary">
        <i class="mdi mdi-arrow-left"></i> Geri
    </a>
</div>

<div class="row">
    <div class="col-md-6 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <form asp-action="CreateTestimony" asp-controller="Admin" method="post">
                    <div class="form-group">
                        <label>Ad Soyad</label>
                        <input type="text" name="Name" class="form-control" placeholder="Ad soyad" required />
                    </div>
                    <div class="form-group">
                        <label>Pozisyon</label>
                        <input type="text" name="Position" class="form-control" placeholder="Müşteri / Öğrenci" required />
                    </div>
                    <div class="form-group">
                        <label>Yorum</label>
                        <textarea name="Content" class="form-control" rows="4" placeholder="Yorum içeriği" required></textarea>
                    </div>
                    <div class="form-group">
                        <label>Profil Resmi URL</label>
                        <input type="text" name="ImageUrl" class="form-control" placeholder="https://..." required />
                    </div>
                    <button type="submit" class="btn btn-primary mr-2">Kaydet</button>
                    <a href="/Admin/Testimonies" class="btn btn-light">İptal</a>
                </form>
            </div>
        </div>
    </div>
</div>
