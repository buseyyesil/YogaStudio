@using YogaStudio.UI.Models
@model List<PackageViewModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Paketler";
}

<div class="page-header">
    <h3 class="page-title">Paketler</h3>
    <a href="/Admin/CreatePackage" class="btn btn-primary">
        <i class="mdi mdi-plus"></i> Yeni Paket Ekle
    </a>
</div>

<div class="row">
    <div class="col-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table">
                        <thead class="bg-light">
                            <tr>
                                <th>#</th>
                                <th>Paket Adı</th>
                                <th>Ders Sayısı</th>
                                <th>Fiyat</th>
                                <th>İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || !Model.Any())
                            {
                                <tr><td colspan="5" class="text-center">Henüz paket eklenmemiş.</td></tr>
                            }
                            else
                            {
                                @foreach (var package in Model)
                                {
                                    <tr>
                                        <td>@package.PackageId</td>
                                        <td>@package.Name</td>
                                        <td>@package.LessonCount</td>
                                        <td>$@package.Price</td>
                                        <td>
                                            <form asp-action="DeletePackage" asp-controller="Admin" method="post" style="display:inline;">
                                                <input type="hidden" name="id" value="@package.PackageId" />
                                                <button type="submit" class="btn btn-sm btn-danger"
                                                        onclick="return confirm('Silmek istediğinize emin misiniz?')">
                                                    <i class="mdi mdi-delete"></i> Sil
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
