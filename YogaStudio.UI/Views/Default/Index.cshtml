        </div>
        <div class="row">
            <div class="col-md-3 ftco-animate">
                <a href="/yogalax-master/images/gallery-1.jpg" class="gallery image-popup img d-flex align-items-center" style="background-image: url('/yogalax-master/images/gallery-1.jpg');">
                    <div class="icon mb-4 d-flex align-items-center justify-content-center"><span class="icon-instagram"></span></div>
                </a>
            </div>
            <div class="col-md-3 ftco-animate">
                <a href="/yogalax-master/images/gallery-2.jpg" class="gallery image-popup img d-flex align-items-center" style="background-image: url('/yogalax-master/images/gallery-2.jpg');">
                    <div class="icon mb-4 d-flex align-items-center justify-content-center"><span class="icon-instagram"></span></div>
                </a>
            </div>
            <div class="col-md-3 ftco-animate">
                <a href="/yogalax-master/images/gallery-3.jpg" class="gallery image-popup img d-flex align-items-center" style="background-image: url('/yogalax-master/images/gallery-3.jpg');">
                    <div class="icon mb-4 d-flex align-items-center justify-content-center"><span class="icon-instagram"></span></div>
                </a>
            </div>
            <div class="col-md-3 ftco-animate">
                <a href="/yogalax-master/images/gallery-4.jpg" class="gallery image-popup img d-flex align-items-center" style="background-image: url('/yogalax-master/images/gallery-4.jpg');">
                    <div class="icon mb-4 d-flex align-items-center justify-content-center"><span class="icon-instagram"></span></div>
                </a>
