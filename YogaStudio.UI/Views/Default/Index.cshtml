@using YogaStudio.UI.Models
@model HomeViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Ana Sayfa";
    var programImages = new[] { "program-1.jpg", "program-2.jpg", "program-3.jpg", "program-4.jpg", "program-5.jpg", "program-6.jpg" };
}

<section class="hero-wrap js-fullheight" style="background-image: url('/yogalax-master/images/bg_2.jpg');">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text js-fullheight align-items-center justify-content-start">
            <div class="col-md-8 ftco-animate">
                <h1 class="typewrite mb-3" data-period="4000" data-type='[ "Neşeli Yaşam İçin İlham.", "Strese Karşı Etkili Terapi.", "Esneklik İkinci Bir Güçtür."]'>
                    <span class="wrap"></span>
                </h1>
                <h2 class="mb-5">Daha iyi bir yarın için bugün Yoga yapın</h2>
                <p><a href="/Schedule/Index" class="btn btn-primary p-3 px-4">15 Gün Ücretsiz Dene</a></p>
            </div>
        </div>
    </div>
</section>

<section class="ftco-section ftco-intro" style="background-image: url('/yogalax-master/images/intro.jpg');">
    <div class="container">
        <div class="row justify-content-end">
            <div class="col-md-6">
                <div class="heading-section ftco-animate">
                    <h2 class="mb-4">Neden Yoga Yapmalısınız?</h2>
                </div>
                <p class="ftco-animate">Beden ve zihin sağlığınız için en doğal yol yogadır. Her yaştan insana uygun derslerimizle hayatınızı dönüştürün. Uzman eğitmenlerimiz eşliğinde kendinizi keşfedin.</p>
                <ul class="mt-5 do-list">
                    <li class="ftco-animate"><a href="#"><span class="ion-ios-checkmark-circle mr-3"></span>Yoga beyin gücünü artırır</a></li>
                    <li class="ftco-animate"><a href="#"><span class="ion-ios-checkmark-circle mr-3"></span>Yoga daha iyi nefes almanıza yardımcı olur</a></li>
                    <li class="ftco-animate"><a href="#"><span class="ion-ios-checkmark-circle mr-3"></span>Yoga gücünüzü ve esnekliğinizi artırır</a></li>
                    <li class="ftco-animate"><a href="#"><span class="ion-ios-checkmark-circle mr-3"></span>Yoga odaklanmanıza yardımcı olur</a></li>
                    <li class="ftco-animate"><a href="#"><span class="ion-ios-checkmark-circle mr-3"></span>Yoga gününüze anlam ve huzur katar</a></li>
                </ul>
            </div>
        </div>
    </div>
</section>

<section class="ftco-section ftco-section-services bg-light">
    <div class="container">
        <div class="row">
            <div class="col-md-3">
                <div class="services ftco-animate">
                    <div class="icon d-flex justify-content-center align-items-center">
                        <span class="flaticon-like"></span>
                    </div>
                    <div class="text mt-4">
                        <h3>Sağlıklı Yaşam</h3>
                        <p>Yoga ile bedeninizi ve zihninizi dengede tutun. Sağlıklı bir yaşam için doğru adımı atın.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="services ftco-animate">
                    <div class="icon d-flex justify-content-center align-items-center">
                        <span class="flaticon-lotus"></span>
                    </div>
                    <div class="text mt-4">
                        <h3>Beden & Zihin Dengesi</h3>
                        <p>İç huzurunuzu bulun, stresden uzaklaşın. Beden ve zihin uyumunu yoga ile yakalayın.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="services ftco-animate">
                    <div class="icon d-flex justify-content-center align-items-center">
                        <span class="flaticon-meditation"></span>
                    </div>
                    <div class="text mt-4">
                        <h3>Meditasyon Pratiği</h3>
                        <p>Düzenli meditasyon ile zihninizi güçlendirin ve odak gücünüzü artırın.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="services ftco-animate">
                    <div class="icon d-flex justify-content-center align-items-center">
                        <span class="flaticon-lotus-1"></span>
                    </div>
                    <div class="text mt-4">
                        <h3>Yoga Felsefesi</h3>
                        <p>Binlerce yıllık yoga geleneğini modern yaşamla buluşturun. Kendinizi keşfedin.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* YOGA CLASSES - DİNAMİK *@
<section class="ftco-section">
    <div class="container">
        <div class="row justify-content-center mb-5 pb-3">
            <div class="col-md-12 heading-section ftco-animate text-center">
                <h3 class="subheading">Yoga Dersleri</h3>
                <h2 class="mb-1">Seviyenizi ve Odak Noktanızı Seçin</h2>
            </div>
        </div>
        <div class="row no-gutters">
            @if (!Model.Lessons.Any())
            {
                <div class="col-12 text-center"><p>Henüz ders eklenmemiş.</p></div>
            }
            else
            {
                @for (int i = 0; i < Model.Lessons.Count; i++)
                {
                    var lesson = Model.Lessons[i];
                    var img = programImages[i % programImages.Length];
                    <div class="col-md-6 col-lg-4">
                        <div class="package-program ftco-animate">
                            <a href="/Schedule/Index" class="img d-flex justify-content-center align-items-center"
                               style="background-image: url('/yogalax-master/images/@img');">
                                <div class="text p-5 text-center">
                                    <h3>@lesson.Name</h3>
                                    <p>@lesson.TrainerName</p>
                                    <p>@lesson.Date.ToString("dd MMM yyyy HH:mm")</p>
                                </div>
                            </a>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

@* PRICING - DİNAMİK *@
<section class="ftco-section bg-light">
    <div class="container">
        <div class="row justify-content-center mb-5 pb-3">
            <div class="col-md-7 heading-section ftco-animate text-center">
                <h3 class="subheading">Üyelik Paketleri</h3>
                <h2 class="mb-1">Size Uygun Paketi Seçin</h2>
            </div>
        </div>
        <div class="row">
            @if (!Model.Packages.Any())
            {
                <div class="col-12 text-center"><p>Henüz paket eklenmemiş.</p></div>
            }
            else
            {
                @foreach (var package in Model.Packages)
                {
                    <div class="col-md-4 ftco-animate">
                        <div class="block-7">
                            <div class="text-center">
                                <h2 class="heading">@package.Name</h2>
                                <span class="price"><sup>₺</sup> <span class="number">@package.Price</span></span>
                                <span class="excerpt d-block">@package.LessonCount Ders Hakkı</span>
                                <h3 class="heading-2 my-4">Tüm Özelliklerin Tadını Çıkarın</h3>
                                <ul class="pricing-text mb-5">
                                    <li>Grup Derslerine Katılım</li>
                                    <li>Fitness Hedefi Görüşmesi</li>
                                    <li>Grup Eğitmeni Desteği</li>
                                    <li>Fitness Yönlendirmesi</li>
                                </ul>
                                <a href="/UserPanel/Packages" class="btn btn-primary d-block px-2 py-4">Hemen Başla</a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

@* TESTIMONY - DİNAMİK *@
<section class="ftco-section testimony-section">
    <div class="container">
        <div class="row justify-content-center mb-5 pb-3">
            <div class="col-md-7 heading-section ftco-animate text-center">
                <h3 class="subheading">Müşteri Yorumları</h3>
                <h2 class="mb-1">Başarı Hikayeleri</h2>
            </div>
        </div>
        <div class="row ftco-animate">
            <div class="col-md-12">
                <div class="carousel-testimony owl-carousel">
                    @if (!Model.Testimonies.Any())
                    {
                        <div class="item">
                            <div class="testimony-wrap p-4 pb-5">
                                <div class="text">
                                    <div class="line pl-5">
                                        <p class="mb-4 pb-1">Henüz yorum eklenmemiş.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        @foreach (var testimony in Model.Testimonies)
                        {
                            <div class="item">
                                <div class="testimony-wrap p-4 pb-5">
                                    <div class="text">
                                        <div class="line pl-5">
                                            <p class="mb-4 pb-1">@testimony.Content</p>
                                            <span class="quote d-flex align-items-center justify-content-center">
                                                <i class="icon-quote-left"></i>
                                            </span>
                                        </div>
                                        <div class="d-flex align-items-center">
                                            <div class="user-img" style="background-image: url('@testimony.ImageUrl')"></div>
                                            <div class="ml-4">
                                                <p class="name">@testimony.Name</p>
                                                <span class="position">@testimony.Position</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<section class="ftco-counter ftco-bg-dark img" id="section-counter" style="background-image: url('/yogalax-master/images/bg_3.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-10">
                <div class="row">
                    <div class="col-md-6 col-lg-3 d-flex justify-content-center counter-wrap ftco-animate">
                        <div class="block-18 text-center">
                            <div class="text">
                                <strong class="number" data-number="5000">0</strong>
                                <span>Mutlu Müşteri</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3 d-flex justify-content-center counter-wrap ftco-animate">
                        <div class="block-18 text-center">
                            <div class="text">
                                <strong class="number" data-number="4560">0</strong>
                                <span>Yoga Atölyesi</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3 d-flex justify-content-center counter-wrap ftco-animate">
                        <div class="block-18 text-center">
                            <div class="text">
                                <strong class="number" data-number="10">0</strong>
                                <span>Yıllık Deneyim</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3 d-flex justify-content-center counter-wrap ftco-animate">
                        <div class="block-18 text-center">
                            <div class="text">
                                <strong class="number" data-number="900">0</strong>
                                <span>Verilen Ders</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* BLOG - DİNAMİK *@
<section class="ftco-section bg-light">
    <div class="container">
        <div class="row justify-content-center mb-5 pb-3">
            <div class="col-md-7 heading-section ftco-animate text-center">
                <h3 class="subheading">Blog</h3>
                <h2 class="mb-1">Son Yazılar</h2>
            </div>
        </div>
        <div class="row d-flex">
            @if (!Model.Blogs.Any())
            {
                <div class="col-12 text-center"><p>Henüz blog yazısı eklenmemiş.</p></div>
            }
            else
            {
                @foreach (var blog in Model.Blogs.Take(3))
                {
                    <div class="col-md-4 d-flex ftco-animate">
                        <div class="blog-entry justify-content-end">
                            <a href="/Blog/Index" class="block-20" style="background-image: url('@blog.ImageUrl');"></a>
                            <div class="text p-4 float-right d-block">
                                <div class="d-flex align-items-center pt-2 mb-4">
                                    <div class="one"><span class="day">@blog.CreatedAt.Day</span></div>
                                    <div class="two">
                                        <span class="yr">@blog.CreatedAt.Year</span>
                                        <span class="mos">@blog.CreatedAt.ToString("MMMM")</span>
                                    </div>
                                </div>
                                <h3 class="heading mt-2"><a href="/Blog/Detail/@blog.BlogPostId">@blog.Title</a></h3>
                                <p>@(blog.Content.Length > 100 ? blog.Content.Substring(0, 100) + "..." : blog.Content)</p>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<section class="ftco-gallery ftco-section">
    <div class="container">
        <div class="row justify-content-center mb-5 pb-3">
            <div class="col-md-7 heading-section ftco-animate text-center">
                <h3 class="subheading">Galeri</h3>
                <h2 class="mb-1">Son Fotoğraflar</h2>
            </div>
        </div>
        <div class="row">
            <div class="col-md-3 ftco-animate">
                <a href="/yogalax-master/images/gallery-1.jpg" class="gallery image-popup img d-flex align-items-center" style="background-image: url('/yogalax-master/images/gallery-1.jpg');">
                    <div class="icon mb-4 d-flex align-items-center justify-content-center"><span class="icon-instagram"></span></div>
                </a>
            </div>
            <div class="col-md-3 ftco-animate">
                <a href="/yogalax-master/images/gallery-2.jpg" class="gallery image-popup img d-flex align-items-center" style="background-image: url('/yogalax-master/images/gallery-2.jpg');">
                    <div class="icon mb-4 d-flex align-items-center justify-content-center"><span class="icon-instagram"></span></div>
                </a>
            </div>
            <div class="col-md-3 ftco-animate">
                <a href="/yogalax-master/images/gallery-3.jpg" class="gallery image-popup img d-flex align-items-center" style="background-image: url('/yogalax-master/images/gallery-3.jpg');">
                    <div class="icon mb-4 d-flex align-items-center justify-content-center"><span class="icon-instagram"></span></div>
                </a>
            </div>
            <div class="col-md-3 ftco-animate">
                <a href="/yogalax-master/images/gallery-4.jpg" class="gallery image-popup img d-flex align-items-center" style="background-image: url('/yogalax-master/images/gallery-4.jpg');">
                    <div class="icon mb-4 d-flex align-items-center justify-content-center"><span class="icon-instagram"></span></div>
                </a>
            </div>
        </div>
    </div>
</section>
