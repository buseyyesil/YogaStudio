@using YogaStudio.UI.Models
@model Dictionary<DayOfWeek, List<LessonViewModel>>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Schedule";

    var days = new[]
    {
        DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday,
        DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday
    };

    var dayNames = new Dictionary<DayOfWeek, string>
    {
        { DayOfWeek.Monday, "Pazartesi" },
        { DayOfWeek.Tuesday, "Salı" },
        { DayOfWeek.Wednesday, "Çarşamba" },
        { DayOfWeek.Thursday, "Perşembe" },
        { DayOfWeek.Friday, "Cuma" },
        { DayOfWeek.Saturday, "Cumartesi" },
        { DayOfWeek.Sunday, "Pazar" }
    };

    var colorClasses = new[] { "color-1", "color-2", "color-3", "color-4", "color-5" };
    var allTimes = Model != null
        ? Model.Values.SelectMany(x => x).Select(x => x.Date.ToString("HH:mm")).Distinct().OrderBy(x => x).ToList()
        : new List<string>();
}

<section class="hero-wrap js-fullheight" style="background-image: url('/yogalax-master/images/bg_3.jpg');">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text js-fullheight align-items-center justify-content-center">
            <div class="col-md-9 ftco-animate text-center">
                <h1 class="mb-3 bread">Yoga Programı</h1>
                <p class="breadcrumbs">
                    <span class="mr-2"><a href="/Default/Index">Home</a></span>
                    <span>Schedule</span>
                </p>
            </div>
        </div>
    </div>
</section>

<section class="ftco-section">
    <div class="container">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible">
                @TempData["Success"]
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible">
                @TempData["Error"]
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        }

        @if (Model == null || !Model.Any())
        {
            <div class="alert alert-info text-center">Henüz ders programı eklenmemiş.</div>
        }
        else
        {
            <div class="row">
                <div class="col-md-12 ftco-animate">
                    <div class="sched-list table-responsive">
                        <table class="table">
                            <thead class="thead-primary">
                                <tr class="text-center">
                                    <th>Saat</th>
                                    @foreach (var day in days)
                                    {
                                        <th>@dayNames[day]</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int colorIndex = 0;
                                }
                                @foreach (var time in allTimes)
                                {
                                    <tr class="text-center">
                                        <td class="color">
                                            <p class="time">@time</p>
                                        </td>
                                        @foreach (var day in days)
                                        {
                                            var lesson = Model.ContainsKey(day)
                                            ? Model[day].FirstOrDefault(x => x.Date.ToString("HH:mm") == time)
                                            : null;
                                            var colorClass = colorClasses[colorIndex % colorClasses.Length];
                                            colorIndex++;

                                            if (lesson != null)
                                            {
                                                var reserved = ViewBag.ReservationCounts != null && ((Dictionary<int, int>)ViewBag.ReservationCounts).ContainsKey(lesson.LessonId)
                                                ? ((Dictionary<int, int>)ViewBag.ReservationCounts)[lesson.LessonId]
                                                : 0;
                                                var isFull = reserved >= lesson.Capacity;

                                                <td class="@colorClass @(isFull ? "opacity-50" : "")">
                                                    <h3>@lesson.Name</h3>
                                                    <span class="at">@lesson.TrainerTitle</span>
                                                    <p class="time">@lesson.Date.ToString("HH:mm") - @lesson.Date.AddMinutes(90).ToString("HH:mm")</p>
                                                    <span class="trainer">@lesson.TrainerName</span>
                                                    <br />
                                       
                                                    <div class="mt-2">
                                                        <span class="badge @(isFull ? "badge-danger" : "badge-success")">
                                                            @reserved / @lesson.Capacity
                                                            @(isFull ? "🔴 Dolu" : "🟢 Müsait")
                                                        </span>
                                                        @if (!string.IsNullOrEmpty(lesson.ZoomLink))
                                                        {
                                                            <div class="mt-2">
                                                                <a href="@lesson.ZoomLink" target="_blank" class="btn btn-sm btn-info">
                                                                    <i class="ion-ios-videocam"></i> Zoom'a Katıl
                                                                </a>
                                                            </div>
                                                        }
                                                    </div>

                                                    @if (!isFull)
                                                    {
                                                        @if (Context.Session.GetInt32("UserId") != null)
                                                        {
                                                            <form method="post" action="/Schedule/Reserve" class="mt-2">
                                                                <input type="hidden" name="lessonId" value="@lesson.LessonId" />
                                                                <button type="submit" class="btn btn-sm btn-primary">
                                                                    <i class="ion-ios-checkmark-circle"></i> Rezervasyon Yap
                                                                </button>
                                                            </form>
                                                        }
                                                        else
                                                        {
                                                            <a href="/Auth/Login?returnUrl=/Schedule/Index" class="btn btn-sm btn-primary mt-2">
                                                                <i class="ion-ios-lock mr-1"></i> Rezervasyon için Giriş Yapın
                                                            </a>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-sm btn-danger mt-2" disabled>Kontenjan Dolu</button>
                                                    }
                                                </td>
                                            }
                                            else
                                            {
                                                <td class="@colorClass"></td>
                                            }
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

       
    </div>
</section>
