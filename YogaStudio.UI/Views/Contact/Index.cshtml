@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Contact";
}

<section class="hero-wrap js-fullheight" style="background-image: url('/yogalax-master/images/bg_3.jpg');">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text js-fullheight align-items-center justify-content-center">
            <div class="col-md-9 ftco-animate text-center">
                <h1 class="mb-3 bread">Contact Us</h1>
                <p class="breadcrumbs">
                    <span class="mr-2"><a href="/Default/Index">Home</a></span>
                    <span>Contact</span>
                </p>
            </div>
        </div>
    </div>
</section>

<section class="ftco-section contact-section">
    <div class="container">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible">
                @TempData["Success"]
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible">
                @TempData["Error"]
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        }

        <div class="row block-9">
            <div class="col-md-4 contact-info ftco-animate bg-light p-4">
                <div class="row">
                    <div class="col-md-12 mb-4">
                        <h2 class="h4">İletişim Bilgileri</h2>
                    </div>
                    <div class="col-md-12 mb-3">
                        <p><span>Adres:</span> Kocaeli, Türkiye</p>
                    </div>
                    <div class="col-md-12 mb-3">
                        <p><span>Telefon:</span> <a href="tel://+905321234567">+90 555 555 5555</a></p>
                    </div>
                    <div class="col-md-12 mb-3">
                        <p><span>Email:</span> <a href="mailto:info@@yogastudio.com">info@@yogastudio.com</a></p>
                    </div>
                    <div class="col-md-12 mb-3">
                        <p><span>Website:</span> <a href="#">yogastudio.com</a></p>
                    </div>
                    <div class="col-md-12 mt-3">
                        <a href="https://wa.me/905321234567?text=Merhaba, yoga dersleri hakkında bilgi almak istiyorum."
                           target="_blank" class="btn btn-success btn-block">
                            <i class="ion-logo-whatsapp mr-2"></i> WhatsApp ile Yaz
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-md-1"></div>
            <div class="col-md-6 ftco-animate">
                <form method="post" action="/Contact/SendMessage" class="contact-form">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <input type="text" name="Name" class="form-control" placeholder="Adınız" required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <input type="email" name="Email" class="form-control" placeholder="Email Adresiniz" required />
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <input type="text" name="Phone" class="form-control" placeholder="Telefon Numaranız" />
                    </div>
                    <div class="form-group">
                        <input type="text" name="Subject" class="form-control" placeholder="Konu" />
                    </div>
                    <div class="form-group">
                        <textarea name="Message" cols="30" rows="7" class="form-control" placeholder="Mesajınız" required></textarea>
                    </div>
                    <div class="form-group">
                        <input type="submit" value="Mesaj Gönder" class="btn btn-primary py-3 px-5" />
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<div id="map" class="map"></div>
