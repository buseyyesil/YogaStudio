@using YogaStudio.UI.Models
@model BlogViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = Model.Title;
    var comments = ViewBag.Comments as List<BlogCommentViewModel> ?? new List<BlogCommentViewModel>();
}

<section class="hero-wrap js-fullheight" style="background-image: url('/yogalax-master/images/bg_3.jpg');">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text js-fullheight align-items-center justify-content-center">
            <div class="col-md-9 ftco-animate text-center">
                <h1 class="mb-3 bread">Blog Detay</h1>
                <p class="breadcrumbs">
                    <span class="mr-2"><a href="/Default/Index">Ana Sayfa</a></span>
                    <span class="mr-2"><a href="/Blog/Index">Blog</a></span>
                    <span>@Model.Title</span>
                </p>
            </div>
        </div>
    </div>
</section>

<section class="ftco-section">
    <div class="container">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible">
                @TempData["Success"]
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible">
                @TempData["Error"]
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        }

        <div class="row">
            <div class="col-lg-8 ftco-animate">
                <h2 class="mb-3">@Model.Title</h2>
                <p class="text-muted mb-4">
                    <span class="icon-calendar mr-2"></span> @Model.CreatedAt.ToString("dd MMMM yyyy")
                </p>

                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <p>
                        <img src="@Model.ImageUrl" alt="@Model.Title" class="img-fluid rounded" />
                    </p>
                }

                <p>@Model.Content</p>

                <div class="tag-widget post-tag-container mb-5 mt-5">
                    <div class="tagcloud">
                        <a href="/Blog/Index" class="tag-cloud-link">Yoga</a>
                        <a href="/Blog/Index" class="tag-cloud-link">Sağlık</a>
                        <a href="/Blog/Index" class="tag-cloud-link">Meditasyon</a>
                        <a href="/Blog/Index" class="tag-cloud-link">Pilates</a>
                    </div>
                </div>

                @* YORUMLAR *@
                <div class="pt-5 mt-5">
                    <h3 class="mb-5">@comments.Count Yorum</h3>

                    @if (!comments.Any())
                    {
                        <p class="text-muted">Henüz yorum yapılmamış. İlk yorumu siz yapın!</p>
                    }
                    else
                    {
                        <ul class="comment-list">
                            @foreach (var comment in comments)
                            {
                                <li class="comment">
                                    <div class="vcard bio">
                                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
                                             style="width:60px; height:60px; font-size:24px; min-width:60px;">
                                            @comment.Name.Substring(0, 1).ToUpper()
                                        </div>
                                    </div>
                                    <div class="comment-body">
                                        <h3>@comment.Name</h3>
                                        <div class="meta">@comment.CreatedAt.ToString("dd MMM yyyy HH:mm")</div>
                                        <p>@comment.Content</p>
                                    </div>
                                </li>
                            }
                        </ul>
                    }

                    @* YORUM FORMU *@
                    <div class="comment-form-wrap pt-5">
                        <h3 class="mb-5">Yorum Yap</h3>
                        <form method="post" action="/Blog/AddComment" class="bg-light p-4">
                            <input type="hidden" name="blogPostId" value="@Model.BlogPostId" />
                            <div class="form-group">
                                <label>Ad Soyad *</label>
                                <input type="text" name="Name" class="form-control bg-white" required />
                            </div>
                            <div class="form-group">
                                <label>Email</label>
                                <input type="email" name="Email" class="form-control bg-white" />
                            </div>
                            <div class="form-group">
                                <label>Yorum *</label>
                                <textarea name="Content" cols="30" rows="7" class="form-control" required></textarea>
                            </div>
                            <div class="form-group">
                                <input type="submit" value="Yorum Gönder" class="btn py-3 px-4 btn-primary" />
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            @* SIDEBAR *@
            <div class="col-lg-4 sidebar ftco-animate">
                <div class="sidebar-box ftco-animate">
                    <h3 class="heading-2">Son Yazılar</h3>
                    @if (ViewBag.RecentBlogs != null)
                    {
                        @foreach (var blog in ViewBag.RecentBlogs)
                        {
                            <div class="block-21 mb-4 d-flex">
                                <a class="blog-img mr-4" href="/Blog/Detail/@blog.BlogPostId"
                                   style="background-image: url('@blog.ImageUrl');"></a>
                                <div class="text">
                                    <h3 class="heading">
                                        <a href="/Blog/Detail/@blog.BlogPostId">@blog.Title</a>
                                    </h3>
                                    <div class="meta">
                                        <div><a href="#"><span class="icon-calendar"></span> @blog.CreatedAt.ToString("dd MMM yyyy")</a></div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>

                <div class="sidebar-box ftco-animate">
                    <h3 class="heading-2">Kategoriler</h3>
                    <li><a href="/Goal/Recommend?goal=weightloss">Zayıflama <span>(3)</span></a></li>
                    <li><a href="/Goal/Recommend?goal=toning">Sıkılaşma <span>(2)</span></a></li>
                    <li><a href="/Goal/Recommend?goal=pregnancy">Hamilelik <span>(2)</span></a></li>
                    <li><a href="/Goal/Recommend?goal=stress">Stres Azaltma <span>(3)</span></a></li>
                </div>

                <div class="sidebar-box ftco-animate">
                    <h3 class="heading-2">Etiketler</h3>
                    <div class="tagcloud">
                        <a href="#" class="tag-cloud-link">yoga</a>
                        <a href="#" class="tag-cloud-link">meditasyon</a>
                        <a href="#" class="tag-cloud-link">pilates</a>
                        <a href="#" class="tag-cloud-link">nefes</a>
                        <a href="#" class="tag-cloud-link">sağlık</a>
                        <a href="#" class="tag-cloud-link">hamilelik</a>
                        <a href="#" class="tag-cloud-link">stres</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
