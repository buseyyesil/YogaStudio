@using YogaStudio.UI.Models
@model List<TrainerViewModel>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Hakkımızda";
}

<section class="hero-wrap js-fullheight" style="background-image: url('/yogalax-master/images/bg_3.jpg');">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text js-fullheight align-items-center justify-content-center">
            <div class="col-md-9 ftco-animate text-center">
                <h1 class="mb-3 bread">YogaStudio Hakkında</h1>
                <p class="breadcrumbs">
                    <span class="mr-2"><a href="/Default/Index">Ana Sayfa</a></span>
                    <span>Hakkımızda</span>
                </p>
            </div>
        </div>
    </div>
</section>

<section class="ftco-section d-md-flex bg-light">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-10 text-center">
                <h2>Duygusal, zihinsel ve ruhsal esnekliğin erdemli ve hayatı zenginleştirici olduğuna inanıyoruz. Yoga pratiğinde bu esneklik her şeyden önce gelir.</h2>
            </div>
        </div>
    </div>
</section>

<section class="ftco-section">
    <div class="container-fluid">
        <div class="row justify-content-center mb-5">
            <div class="col-md-12 heading-section text-center ftco-animate">
                <h3 class="subheading">Eğitmenlerimiz</h3>
                <h2 class="mb-1">Yoga Eğitmenlerimizle Tanışın</h2>
            </div>
        </div>
        <div class="row">
            @if (Model == null || !Model.Any())
            {
                <div class="col-12 text-center"><p>Henüz eğitmen eklenmemiş.</p></div>
            }
            else
            {
                @foreach (var trainer in Model)
                {
                    <div class="col-lg-3 d-flex">
                        <div class="coach align-items-stretch">
                            <div class="img" style="background-image: url('@trainer.ImageUrl');"></div>
                            <div class="text bg-white p-4 ftco-animate">
                                <span class="subheading">@trainer.Title</span>
                                <h3><a href="#">@trainer.Name @trainer.Surname</a></h3>
                                <ul class="ftco-social-media d-flex mt-4">
                                    <li class="ftco-animate"><a href="#" class="mr-2 d-flex justify-content-center align-items-center"><span class="icon-twitter"></span></a></li>
                                    <li class="ftco-animate"><a href="#" class="mr-2 d-flex justify-content-center align-items-center"><span class="icon-facebook"></span></a></li>
                                    <li class="ftco-animate"><a href="#" class="mr-2 d-flex justify-content-center align-items-center"><span class="icon-instagram"></span></a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<section class="ftco-section bg-light">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-12 heading-section text-center ftco-animate">
                <h3 class="subheading">Misyonumuz</h3>
                <h2 class="mb-1">Neden YogaStudio?</h2>
            </div>
        </div>
        <div class="row">
            <div class="col-md-4 text-center ftco-animate">
                <div class="p-4">
                    <span style="font-size:50px;">🧘</span>
                    <h4 class="mt-3">Uzman Eğitmenler</h4>
                    <p class="text-muted">Alanında uzman, sertifikalı eğitmenlerimizle en doğru yoga deneyimini yaşayın.</p>
                </div>
            </div>
            <div class="col-md-4 text-center ftco-animate">
                <div class="p-4">
                    <span style="font-size:50px;">💆</span>
                    <h4 class="mt-3">Kişiselleştirilmiş Program</h4>
                    <p class="text-muted">Hedefinize özel hazırlanan programlarla daha hızlı sonuç alın.</p>
                </div>
            </div>
            <div class="col-md-4 text-center ftco-animate">
                <div class="p-4">
                    <span style="font-size:50px;">🌿</span>
                    <h4 class="mt-3">Huzurlu Ortam</h4>
                    <p class="text-muted">Modern ve huzurlu stüdyomuzda kendinizi tamamen özgür hissedin.</p>
                </div>
            </div>
        </div>
    </div>
</section>
