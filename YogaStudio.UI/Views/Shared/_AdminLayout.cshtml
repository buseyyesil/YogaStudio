<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>YogaStudio Admin</title>
    <link rel="stylesheet" href="~/Breeze-Free-Bootstrap-Admin-Template-1.0.0/template/assets/vendors/mdi/css/materialdesignicons.min.css" />
    <link rel="stylesheet" href="~/Breeze-Free-Bootstrap-Admin-Template-1.0.0/template/assets/vendors/css/vendor.bundle.base.css" />
    <link rel="stylesheet" href="~/Breeze-Free-Bootstrap-Admin-Template-1.0.0/template/assets/css/style.css" />
</head>
<body>
    <div class="container-scroller">

        @* SIDEBAR *@
        <nav class="sidebar sidebar-offcanvas" id="sidebar">
            <div class="text-center sidebar-brand-wrapper d-flex align-items-center">
                <a class="sidebar-brand brand-logo" href="/Admin/Index">
                    <span style="color:white; font-size:20px; font-weight:bold;">YogaStudio</span>
                </a>
            </div>
            <ul class="nav">
                <li class="nav-item nav-profile">
                    <a href="#" class="nav-link">
                        <div class="nav-profile-text d-flex flex-column pr-3">
                            <span class="font-weight-medium mb-2">@Context.Session.GetString("Username")</span>
                            <span class="font-weight-normal">Admin</span>
                        </div>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/Index">
                        <i class="mdi mdi-home menu-icon"></i>
                        <span class="menu-title">Dashboard</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/Lessons">
                        <i class="mdi mdi-calendar menu-icon"></i>
                        <span class="menu-title">Dersler</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/Trainers">
                        <i class="mdi mdi-account menu-icon"></i>
                        <span class="menu-title">Eğitmenler</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/Packages">
                        <i class="mdi mdi-package menu-icon"></i>
                        <span class="menu-title">Paketler</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/Blogs">
                        <i class="mdi mdi-newspaper menu-icon"></i>
                        <span class="menu-title">Blog</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/Messages">
                        <i class="mdi mdi-email menu-icon"></i>
                        <span class="menu-title">Mesajlar</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/Testimonies">
                        <i class="mdi mdi-comment menu-icon"></i>
                        <span class="menu-title">Yorumlar</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/Reservations">
                        <i class="mdi mdi-bookmark menu-icon"></i>
                        <span class="menu-title">Rezervasyonlar</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/Users">
                        <i class="mdi mdi-account-multiple menu-icon"></i>
                        <span class="menu-title">Kullanıcılar</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Auth/Logout">
                        <i class="mdi mdi-logout menu-icon"></i>
                        <span class="menu-title">Çıkış</span>
                    </a>
                </li>
            </ul>
        </nav>

        <div class="container-fluid page-body-wrapper">
            @* NAVBAR *@
            <nav class="navbar col-lg-12 col-12 p-lg-0 fixed-top d-flex flex-row">
                <div class="navbar-menu-wrapper d-flex align-items-stretch justify-content-between">
                    <button class="navbar-toggler navbar-toggler align-self-center mr-2" type="button" data-toggle="minimize">
                        <i class="mdi mdi-menu"></i>
                    </button>
                    <ul class="navbar-nav navbar-nav-right ml-lg-auto">
                        <li class="nav-item nav-profile dropdown border-0">
                            <a class="nav-link dropdown-toggle" id="profileDropdown" href="#" data-toggle="dropdown">
                                <span class="profile-name">@Context.Session.GetString("Username")</span>
                            </a>
                            <div class="dropdown-menu navbar-dropdown w-100" aria-labelledby="profileDropdown">
                                <a class="dropdown-item" href="/Default/Index">
                                    <i class="mdi mdi-home mr-2 text-success"></i> Siteye Git
                                </a>
                                <a class="dropdown-item" href="/Auth/Logout">
                                    <i class="mdi mdi-logout mr-2 text-primary"></i> Çıkış
                                </a>
                            </div>
                        </li>
                    </ul>
                    <button class="navbar-toggler navbar-toggler-right d-lg-none align-self-center" type="button" data-toggle="offcanvas">
                        <span class="mdi mdi-menu"></span>
                    </button>
                </div>
            </nav>

            <div class="main-panel">
                <div class="content-wrapper">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }
                    @RenderBody()
                </div>
                <footer class="footer">
                    <div class="d-sm-flex justify-content-center justify-content-sm-between">
                        <span class="text-muted d-block text-center text-sm-left d-sm-inline-block">
                            Copyright &copy; @DateTime.Now.Year YogaStudio Admin
                        </span>
                    </div>
                </footer>
            </div>
        </div>
    </div>

    <script src="~/Breeze-Free-Bootstrap-Admin-Template-1.0.0/template/assets/vendors/js/vendor.bundle.base.js"></script>
    <script src="~/Breeze-Free-Bootstrap-Admin-Template-1.0.0/template/assets/js/off-canvas.js"></script>
    <script src="~/Breeze-Free-Bootstrap-Admin-Template-1.0.0/template/assets/js/hoverable-collapse.js"></script>
    <script src="~/Breeze-Free-Bootstrap-Admin-Template-1.0.0/template/assets/js/misc.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
