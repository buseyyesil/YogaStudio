<!DOCTYPE html>
<html lang="tr">
<head>
    <title>YogaStudio</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <link href="https://fonts.googleapis.com/css?family=Work+Sans:100,200,300,400,500,600,700,800,900" rel="stylesheet">

    <link rel="stylesheet" href="~/yogalax-master/css/open-iconic-bootstrap.min.css">
    <link rel="stylesheet" href="~/yogalax-master/css/animate.css">

    <link rel="stylesheet" href="~/yogalax-master/css/owl.carousel.min.css">
    <link rel="stylesheet" href="~/yogalax-master/css/owl.theme.default.min.css">
    <link rel="stylesheet" href="~/yogalax-master/css/magnific-popup.css">

    <link rel="stylesheet" href="~/yogalax-master/css/aos.css">

    <link rel="stylesheet" href="~/yogalax-master/css/ionicons.min.css">

    <link rel="stylesheet" href="~/yogalax-master/css/bootstrap-datepicker.css">
    <link rel="stylesheet" href="~/yogalax-master/css/jquery.timepicker.css">

    <link rel="stylesheet" href="~/yogalax-master/css/flaticon.css">
    <link rel="stylesheet" href="~/yogalax-master/css/icomoon.css">
    <link rel="stylesheet" href="~/yogalax-master/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark ftco_navbar bg-dark ftco-navbar-light" id="ftco-navbar">
        <div class="container">
            <a class="navbar-brand" href="/Default/Index">
                <span class="flaticon-lotus"></span>YogaStudio
            </a>
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#ftco-nav" aria-controls="ftco-nav" aria-expanded="false" aria-label="Menüyü Aç">
                <span class="oi oi-menu"></span> Menü
            </button>

            <div class="collapse navbar-collapse" id="ftco-nav">
                <ul class="navbar-nav ml-auto">
                    <li class="nav-item"><a href="/Default/Index" class="nav-link">Ana Sayfa</a></li>
                    <li class="nav-item"><a href="/Classes/Index" class="nav-link">Dersler</a></li>
                    <li class="nav-item"><a href="/Schedule/Index" class="nav-link">Program</a></li>
                    <li class="nav-item"><a href="/About/Index" class="nav-link">Hakkımızda</a></li>
                    <li class="nav-item"><a href="/Blog/Index" class="nav-link">Blog</a></li>
                    <li class="nav-item"><a href="/Goal/Index" class="nav-link">Program Öner</a></li>
                    <li class="nav-item"><a href="/Contact/Index" class="nav-link">İletişim</a></li>
                    @if (Context.Session.GetString("Username") != null)
                    {
                        <li class="nav-item">
                            <a href="/UserPanel/Index" class="nav-link text-warning">
                                Merhaba, @Context.Session.GetString("Username")
                            </a>
                        </li>
                        @if (Context.Session.GetString("Role") == "Admin")
                        {
                            <li class="nav-item">
                                <a href="/Admin/Index" class="nav-link" style="color:#f96d00;">
                                    <i class="ion-ios-settings"></i> Admin Panel
                                </a>
                            </li>
                        }
                        <li class="nav-item"><a href="/Auth/Logout" class="nav-link">Çıkış</a></li>
                    }
                    else
                    {
                        <li class="nav-item"><a href="/Auth/Login" class="nav-link">Giriş Yap</a></li>
          
                    }
                </ul>
            </div>
        </div>
    </nav>
    <!-- END nav -->
    @RenderBody()

    <footer class="ftco-footer ftco-section img">
        <div class="overlay"></div>
        <div class="container">
            <div class="row mb-5">
                <div class="col-lg-3 col-md-6 mb-5 mb-md-5 ftco-animate">
                    <div class="ftco-footer-widget mb-4">
                        <h1 class="logo">YogaStudio</h1>
                    </div>
                </div>
                <div class="col-lg col-md-6 mb-5 mb-md-5 ftco-animate">
                    <div class="ftco-footer-widget mb-4">
                        <h2 class="location">Kocaeli, Türkiye</h2>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 mb-5 mb-md-5">
                    <div class="ftco-footer-widget mb-4">
                        <ul class="ftco-footer-social list-unstyled float-md-left float-lft">
                            <li class="ftco-animate"><a href="#"><span class="icon-twitter"></span></a></li>
                            <li class="ftco-animate"><a href="#"><span class="icon-facebook"></span></a></li>
                            <li class="ftco-animate"><a href="#"><span class="icon-instagram"></span></a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12 text-center">
                    <p>
                        Copyright &copy; @DateTime.Now.Year
                        Tüm Hakları Saklıdır | YogaStudio
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/yogalax-master/js/jquery.min.js"></script>
    <script src="~/yogalax-master/js/jquery-migrate-3.0.1.min.js"></script>
    <script src="~/yogalax-master/js/popper.min.js"></script>
    <script src="~/yogalax-master/js/bootstrap.min.js"></script>
    <script src="~/yogalax-master/js/jquery.easing.1.3.js"></script>
    <script src="~/yogalax-master/js/jquery.waypoints.min.js"></script>
    <script src="~/yogalax-master/js/jquery.stellar.min.js"></script>
    <script src="~/yogalax-master/js/owl.carousel.min.js"></script>
    <script src="~/yogalax-master/js/jquery.magnific-popup.min.js"></script>
    <script src="~/yogalax-master/js/aos.js"></script>
    <script src="~/yogalax-master/js/jquery.animateNumber.min.js"></script>
    <script src="~/yogalax-master/js/bootstrap-datepicker.js"></script>
    <script src="~/yogalax-master/js/jquery.timepicker.min.js"></script>
    <script src="~/yogalax-master/js/scrollax.min.js"></script>
    <script src="~/yogalax-master/js/google-map.js"></script>
    <script src="~/yogalax-master/js/main.js"></script>

    @RenderSection("Scripts", required: false)

    @* WHATSAPP BUTONU *@
    <a href="https://wa.me/9053212355555?text=Merhaba, yoga dersleri hakkında bilgi almak istiyorum."
       target="_blank"
       style="position:fixed; bottom:30px; right:30px; z-index:9999; background-color:#25D366;
          color:white; border-radius:50%; width:60px; height:60px;
          display:flex; align-items:center; justify-content:center;
          box-shadow: 2px 2px 10px rgba(0,0,0,0.3); font-size:30px;">
        <i class="ion-logo-whatsapp"></i>
    </a>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        @if (TempData["Success"] != null)
        {
            <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Başarılı!',
                text: '@Html.Raw(TempData["Success"])',
                    confirmButtonText: 'Tamam',
                    confirmButtonColor: '#f96d00'
                });
            </text>
        }
        @if (TempData["Error"] != null)
        {
            <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Hata!',
                      text: '@Html.Raw(TempData["Error"])',
                    confirmButtonText: 'Tamam'
                });
            </text>
        }
    </script>
</body>
</html>
